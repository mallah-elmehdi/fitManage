// ------------------------------- ONE SESSION BTREAKDOWN

model ExerciseFormat {
    id    Int             @id @default(autoincrement())
    name  String
    focus TrainingFocus[]

    image String?
    video String?

    primary_muscles    Muscle[] // agonist 
    secondary_muscles  Muscle[] //  Synergists
    stabilizer_muscles Muscle[] //  Stabilizers
    opposite_muscles   Muscle[] //  Antagonists

    appropriate_fitness_level   FitnessLevel
    appropriate_training_phases TrainingPhase[]

    Exercise Exercise[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Exercise {
    id               Int            @id @default(autoincrement())
    exercise_format  ExerciseFormat @relation(fields: [exerciseFormatId], references: [id])
    exerciseFormatId Int

    exercise_type ExerciseType

    set        Int?
    repetition Int?
    tempo      Tempo?
    rest       Int        @default(30) // in seconds
    intensity  Intensity?

    WorkoutSession   WorkoutSession? @relation(fields: [workoutSessionId], references: [id])
    workoutSessionId Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ------------------------------- TRAINING PLAN BTREAKDOWN

model Macrocycle {
    id        Int      @id @default(autoincrement())
    name      String
    startDate DateTime
    endDate   DateTime

    mesocycles Mesocycle[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Mesocycle {
    id        Int      @id @default(autoincrement())
    startDate DateTime
    endDate   DateTime

    macrocycle   Macrocycle @relation(fields: [macrocycleId], references: [id])
    macrocycleId Int

    microcycles Microcycle[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Microcycle {
    id        Int      @id @default(autoincrement())
    startDate DateTime
    endDate   DateTime

    mesocycle   Mesocycle @relation(fields: [mesocycleId], references: [id])
    mesocycleId Int

    workoutSessions WorkoutSession[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model WorkoutSession {
    id   Int      @id @default(autoincrement())
    date DateTime

    athlete   Athlete @relation(fields: [athleteId], references: [id])
    athleteId Int

    microcycle   Microcycle @relation(fields: [microcycleId], references: [id])
    microcycleId Int

    training_level TrainingLevel?
    training_phase TrainingPhase?

    exercises Exercise[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
